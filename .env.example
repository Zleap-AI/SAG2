# ============================================================================
# DataFlow Environment Configuration Sample
# ============================================================================
# Copy this file to .env and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sag2
MYSQL_PASSWORD=sag2_pass
MYSQL_DATABASE=sag2

# Database connection pool settings
DB_POOL_SIZE=100
DB_MAX_OVERFLOW=200
DB_POOL_RECYCLE=3600

# ============================================================================
# Elasticsearch Configuration
# ============================================================================
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=elastic
ELASTIC_PASSWORD=your_password
ES_SCHEME=http

# ============================================================================
# LLM Configuration (Primary Language Model)
# ============================================================================
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.302ai.com/v1
LLM_MODEL=qwen3.6-flash

# Model Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=30000
LLM_TOP_P=1.0
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0

# Reliability Settings
LLM_TIMEOUT=300
LLM_MAX_RETRIES=5

# Language Setting (zh / en)
LLM_LANGUAGE=en

# ============================================================================
# Embedding Model Configuration
# ============================================================================
EMBEDDING_API_KEY=1
EMBEDDING_BASE_URL=http://192.168.110.12:9990/v1
EMBEDDING_MODEL_NAME=text-embedding-bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# ============================================================================
# MLflow Configuration
# ============================================================================
# MLflow Docker container port mapping (used in docker-compose.mlflow.yml)
MLFLOW_PORT=5000

# MLflow Tracking Server URL (used by run_search_benchmark.py --mlflow-url)
# Format: http://<host>:<port>
# Examples:
#   - Local: http://localhost:5000
#   - Remote: http://192.168.1.100:5000
MLFLOW_URL=http://localhost:5000

# ============================================================================
# Application Settings
# ============================================================================
SERVER_TYPE=LOCAL
LOG_LEVEL=INFO
DEBUG=false
BENCHMARK=false
